---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import StickyCta from '../components/StickyCta.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
}

const {
  title,
  description,
  canonical = new URL(Astro.url.pathname, Astro.site).href,
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_ID;

// Sitewide structured data (FinancialService is a LocalBusiness subtype).
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'FinancialService',
  '@id': 'https://canyonstrategicwealth.com/#organization',
  name: 'Canyon Strategic Wealth',
  description:
    'Fiduciary private wealth advisory and virtual family office serving Utah families and business owners with $1M+ in investable assets.',
  url: 'https://canyonstrategicwealth.com',
  telephone: '+1-801-903-8287',
  email: 'jake@canyonstrategicwealth.com',
  logo: 'https://canyonstrategicwealth.com/canyon-logo.png',
  image: 'https://canyonstrategicwealth.com/canyon-logo.png',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '450 S 400 E',
    addressLocality: 'Bountiful',
    addressRegion: 'UT',
    postalCode: '84010',
    addressCountry: 'US',
  },
  foundingDate: '2017',
  founder: {
    '@type': 'Person',
    name: 'Jake Cazier',
    jobTitle: 'Private Wealth Advisor & Owner',
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Professional Certification',
      name: 'CERTIFIED FINANCIAL PLANNER (CFP)',
    },
  },
  areaServed: [
    'Bountiful, UT',
    'Centerville, UT',
    'Farmington, UT',
    'Kaysville, UT',
    'Salt Lake City, UT',
    'Davis County, UT',
  ],
  serviceType: [
    'Investment Management',
    'Financial Planning',
    'Tax Strategy',
    'Estate Planning',
    'Risk Management',
    'Business Owner Advisory',
  ],
  priceRange: '$$$$',
  sameAs: ['https://adviserinfo.sec.gov/firm/summary/325175'],
  knowsAbout: [
    'Wealth Management',
    'Virtual Family Office',
    'Financial Planning',
    'Investment Advisory',
  ],
};
---

<!doctype html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="Canyon Strategic Wealth" />

    <!-- Open Graph / Twitter -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:site_name" content="Canyon Strategic Wealth" />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Sitewide structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} is:inline />

    <!-- Per-page structured data and head extras -->
    <slot name="head" />

    <!-- Smooth, accessible page transitions across the site -->
    <ClientRouter />

    {
      gaId && (
        <>
          <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`} />
          <script is:inline define:vars={{ gaId }}>
            window.dataLayer = window.dataLayer || [];
            function gtag() {
              dataLayer.push(arguments);
            }
            gtag('js', new Date());
            gtag('config', gaId);
          </script>
        </>
      )
    }
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
    <StickyCta />

    <script>
      // Fade-in on scroll. Re-binds after each ClientRouter page transition.
      function setupFadeIn() {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) entry.target.classList.add('visible');
            });
          },
          { threshold: 0.1 },
        );
        document.querySelectorAll('.fade-in').forEach((el) => observer.observe(el));
      }

      // Animated count-up for numeric stat elements with [data-count-to].
      function animateCount(el: HTMLElement) {
        if (el.dataset.counted === '1') return;
        el.dataset.counted = '1';
        const to = parseFloat(el.dataset.countTo || '');
        if (isNaN(to)) return;
        const from = el.dataset.from ? parseFloat(el.dataset.from) : 0;
        const prefix = el.dataset.prefix || '';
        const suffix = el.dataset.suffix || '';
        const duration = 1400;
        const start = performance.now();
        const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);
        function tick(now: number) {
          const t = Math.min((now - start) / duration, 1);
          const value = Math.round(from + (to - from) * easeOutQuart(t));
          el.textContent = prefix + value + suffix;
          if (t < 1) requestAnimationFrame(tick);
        }
        requestAnimationFrame(tick);
      }

      function setupCountUp() {
        const els = document.querySelectorAll<HTMLElement>('[data-count-to]');
        if (!els.length) return;
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) animateCount(entry.target as HTMLElement);
            });
          },
          { threshold: 0.4 },
        );
        els.forEach((el) => {
          el.dataset.counted = '';
          observer.observe(el);
        });
      }

      // Process-timeline progress line: a vertical accent line "draws in" as
      // the user scrolls through the timeline. The CSS reads --progress to
      // size the fill, so no markup change is needed in process.astro.
      function setupTimelineProgress() {
        const timeline = document.querySelector<HTMLElement>('.process-timeline');
        if (!timeline) return;
        function update() {
          if (!timeline) return;
          const rect = timeline.getBoundingClientRect();
          const viewH = window.innerHeight;
          const total = rect.height + viewH * 0.6;
          const seen = Math.min(Math.max(viewH * 0.6 - rect.top, 0), total);
          const pct = Math.min((seen / total) * 100, 100);
          timeline.style.setProperty('--progress', pct + '%');
        }
        update();
        const w = window as unknown as { __canyonTimelineScroll?: () => void };
        if (w.__canyonTimelineScroll) {
          window.removeEventListener('scroll', w.__canyonTimelineScroll);
          window.removeEventListener('resize', w.__canyonTimelineScroll);
        }
        w.__canyonTimelineScroll = update;
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
      }

      function initPage() {
        setupFadeIn();
        setupCountUp();
        setupTimelineProgress();
      }
      document.addEventListener('astro:page-load', initPage);
    </script>
  </body>
</html>
