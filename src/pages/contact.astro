---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact | Canyon Strategic Wealth — Bountiful, UT"
  description="Get in touch with Canyon Strategic Wealth. Office at 450 S 400 E, Bountiful, UT 84010. Call (801) 903-8287, email jake@canyonstrategicwealth.com, or schedule a complimentary discovery call."
>
  <div class="page-header">
    <h1>Get In Touch</h1>
    <p>Have a question or ready to start? We'd love to hear from you.</p>
  </div>

  <section class="section">
    <div class="contact-grid">
      <div class="contact-info-cards">
        <a href="mailto:jake@canyonstrategicwealth.com" class="contact-card">
          <div class="contact-card-icon" style="background:var(--sky-pale);"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" /><polyline points="22 4 12 13 2 4" /></svg></div>
          <div>
            <h4>Email Us</h4>
            <p>jake@canyonstrategicwealth.com</p>
          </div>
        </a>
        <a href="tel:+18019038287" class="contact-card">
          <div class="contact-card-icon" style="background:rgba(201,168,76,0.12);"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6A19.79 19.79 0 012.12 4.18 2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" /></svg></div>
          <div>
            <h4>Call Us</h4>
            <p>(801) 903-8287</p>
          </div>
        </a>
        <a
          href="https://maps.google.com/?q=450+S+400+E+Bountiful+UT+84010"
          target="_blank"
          rel="noopener"
          class="contact-card"
        >
          <div class="contact-card-icon" style="background:var(--sky-pale);"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg></div>
          <div>
            <h4>Our Office</h4>
            <p>450 S 400 E<br />Bountiful, UT 84010</p>
          </div>
        </a>
        <div class="contact-card">
          <div class="contact-card-icon" style="background:rgba(201,168,76,0.12);"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg></div>
          <div>
            <h4>Office Hours</h4>
            <p>Monday – Friday, 8am – 5pm MT</p>
          </div>
        </div>
      </div>
      <form class="contact-form" id="contactForm" action="/api/contact" method="POST">
        <h3>Send Us a Message</h3>
        <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none" />
        <input type="hidden" name="formType" value="contact" />
        <div class="form-row">
          <div class="form-group">
            <label for="firstName">First Name</label>
            <input type="text" id="firstName" name="firstName" placeholder="Your first name" required />
          </div>
          <div class="form-group">
            <label for="lastName">Last Name</label>
            <input type="text" id="lastName" name="lastName" placeholder="Your last name" required />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="your@email.com" required />
        </div>
        <div class="form-group">
          <label for="phone">Phone (Optional)</label>
          <input type="tel" id="phone" name="phone" placeholder="(555) 555-5555" />
        </div>
        <div class="form-group">
          <label for="topic">What can we help with?</label>
          <select id="topic" name="topic">
            <option value="">Select a topic...</option>
            <option value="planning">Financial Planning</option>
            <option value="investment">Investment Management</option>
            <option value="tax">Tax Strategy</option>
            <option value="estate">Estate Planning</option>
            <option value="business">Business Advisory</option>
            <option value="other">Something Else</option>
          </select>
        </div>
        <div class="form-group">
          <label for="message">Message</label>
          <textarea id="message" name="message" placeholder="Tell us a little about your situation and what you're looking for..." required></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;">Send Message</button>
        <p class="form-status" id="contactStatus" role="status" aria-live="polite" style="margin-top:14px;font-size:14px;text-align:center;min-height:1em;"></p>
      </form>
    </div>
  </section>

  <section class="section section-dark">
    <div style="text-align:center;margin-bottom:48px;position:relative;z-index:2;">
      <div class="section-eyebrow">Schedule Directly</div>
      <h2 class="section-title light">Prefer to Book a Time?</h2>
      <p class="section-subtitle light" style="margin:0 auto;">Choose the meeting type that works best for you.</p>
    </div>
    <div class="schedule-cards">
      <a href="https://calendly.com/jakecazier/discovery-meeting" target="_blank" rel="noopener" class="schedule-card">
        <div class="schedule-card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" /></svg></div>
        <h4>Discovery Call</h4>
        <p>An introductory conversation to discuss your financial goals and see if we're the right fit.</p>
        <span class="badge badge-sky">Schedule Now &rarr;</span>
      </a>
      <a href="https://calendly.com/jakecazier/client-quick-chat" target="_blank" rel="noopener" class="schedule-card">
        <div class="schedule-card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 010 8h-1" /><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z" /><line x1="6" y1="1" x2="6" y2="4" /><line x1="10" y1="1" x2="10" y2="4" /><line x1="14" y1="1" x2="14" y2="4" /></svg></div>
        <h4>Quick Chat (15 min)</h4>
        <p>Have a quick question? Book a brief call with Jake to get a fast answer.</p>
        <span class="badge badge-gold">Schedule Now &rarr;</span>
      </a>
      <a href="https://calendly.com/jakecazier/client-meeting-custom-calendar" target="_blank" rel="noopener" class="schedule-card">
        <div class="schedule-card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg></div>
        <h4>Client Meeting</h4>
        <p>For existing clients — schedule a full meeting outside the regular onboarding flow.</p>
        <span class="badge badge-sky">Schedule Now &rarr;</span>
      </a>
      <a href="mailto:jake@canyonstrategicwealth.com" class="schedule-card">
        <div class="schedule-card-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2" /><polyline points="22 4 12 13 2 4" /></svg></div>
        <h4>Email Jake Directly</h4>
        <p>Prefer email? Reach out anytime and we'll get back to you within one business day.</p>
        <span class="badge badge-gold">Send Email &rarr;</span>
      </a>
    </div>
  </section>

  <script>
    const form = document.getElementById('contactForm') as HTMLFormElement | null;
    const status = document.getElementById('contactStatus');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const payload: Record<string, string> = {};
      new FormData(form).forEach((value, key) => {
        payload[key] = String(value);
      });
      if (status) status.textContent = '';
      if (btn && !btn.dataset.label) btn.dataset.label = btn.innerHTML;
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Sending…';
      }
      fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then((res) =>
          res
            .json()
            .catch(() => ({}))
            .then((data) => ({ ok: res.ok, data })),
        )
        .then((result) => {
          if (!status) return;
          if (result.ok) {
            form.reset();
            status.textContent =
              'Thank you. Your message has been sent — we will be in touch within one business day.';
            status.style.color = '#1B7A3D';
          } else {
            status.textContent =
              (result.data && (result.data as { error?: string }).error) ||
              'Something went wrong. Please email jake@canyonstrategicwealth.com or call (801) 903-8287.';
            status.style.color = '#C0392B';
          }
        })
        .catch(() => {
          if (status) {
            status.textContent =
              'Something went wrong. Please email jake@canyonstrategicwealth.com or call (801) 903-8287.';
            status.style.color = '#C0392B';
          }
        })
        .then(() => {
          if (btn) {
            btn.disabled = false;
            if (btn.dataset.label) btn.innerHTML = btn.dataset.label;
          }
        });
    });
  </script>
</BaseLayout>
