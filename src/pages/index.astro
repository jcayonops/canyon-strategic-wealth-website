---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
---

<BaseLayout
  title="Canyon Strategic Wealth — Private Wealth Advisory & Virtual Family Office"
  description="Canyon Strategic Wealth is a fiduciary virtual family office in Bountiful, Utah, serving families and business owners with $1M+ in investable assets — coordinating investments, tax, estate, and risk into one strategy."
>
  <section class="hero">
    <div class="hero-content">
      <div class="hero-eyebrow">Private Wealth Advisory</div>
      <h1 class="hero-title">Your Financial Life,<br /><span>Strategically Coordinated</span></h1>
      <p class="hero-text">Canyon Strategic Wealth is a fiduciary virtual family office serving Utah families and business owners with $1M+ in investable assets — coordinating investments, taxes, estate planning, and risk management into one seamless strategy built around your life.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="https://calendly.com/jakecazier/discovery-meeting" target="_blank" rel="noopener">Schedule a Discovery Call</a>
        <a class="btn btn-outline" href="/services">Explore Our Services</a>
      </div>
      <div class="hero-stats">
        <div>
          <div class="hero-stat-number">CFP&reg;</div>
          <div class="hero-stat-label">Certified Planner</div>
        </div>
        <div>
          <div class="hero-stat-number">100%</div>
          <div class="hero-stat-label">Fiduciary Always</div>
        </div>
        <div>
          <div class="hero-stat-number">360&deg;</div>
          <div class="hero-stat-label">Holistic Planning</div>
        </div>
      </div>
    </div>
    <div class="hero-geo">
      <div class="geo-ring"></div>
      <div class="geo-ring"></div>
      <div class="geo-ring"></div>
      <div class="geo-dot"></div>
      <div class="geo-dot"></div>
      <div class="geo-dot"></div>
      <div class="geo-dot"></div>
    </div>
  </section>

  <div class="trust-bar" role="region" aria-label="Credentials and Trust Indicators">
    <div class="trust-bar-inner">
      <div class="trust-badge">
        <div class="trust-badge-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H3V6a1 1 0 011-1h2" /><path d="M18 9h3V6a1 1 0 00-1-1h-2" /><path d="M6 5h12v7a6 6 0 01-12 0V5z" /><path d="M12 18v3" /><path d="M8 21h8" /></svg></div>
        <span>CFP&reg; Certified</span>
      </div>
      <div class="trust-badge">
        <div class="trust-badge-icon gold-bg"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg></div>
        <span>Fiduciary Standard</span>
      </div>
      <div class="trust-badge">
        <div class="trust-badge-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="3" x2="12" y2="21" /><line x1="4" y1="7" x2="20" y2="7" /><path d="M4 7l2 8h0a3 3 0 006 0h0l2-8" /><path d="M14 7l2 8h0a3 3 0 006 0h0l2-8" /><line x1="8" y1="21" x2="16" y2="21" /></svg></div>
        <span>SEC Registered RIA</span>
      </div>
      <div class="trust-badge">
        <div class="trust-badge-icon gold-bg"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2" /><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" /><line x1="2" y1="13" x2="22" y2="13" /></svg></div>
        <span>Fee-Based Advisor</span>
      </div>
      <div class="trust-badge">
        <div class="trust-badge-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 17l-1.5 1.5a2.12 2.12 0 01-3 0L4 16a2.12 2.12 0 010-3l1-1" /><path d="M13 7l1.5-1.5a2.12 2.12 0 013 0L20 8a2.12 2.12 0 010 3l-1 1" /><path d="M8 12l4 4" /><path d="M12 8l4 4" /><path d="M3.5 11L8 6.5" /><path d="M16 17.5L20.5 13" /></svg></div>
        <span>Fiduciary Oath</span>
      </div>
    </div>
  </div>

  <section class="values-strip">
    <div class="values-grid">
      <div class="value-item fade-in">
        <div class="value-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="17" /><line x1="18" y1="3" x2="18" y2="17" /><line x1="12" y1="3" x2="12" y2="17" /><path d="M2 17h20" /><path d="M2 20h20" /><path d="M4 3h16" /></svg></div>
        <div class="value-name">Fiduciary First</div>
        <div class="value-desc">Legally and ethically required to act in your best interest — always.</div>
      </div>
      <div class="value-item fade-in">
        <div class="value-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg></div>
        <div class="value-name">Transparency</div>
        <div class="value-desc">No hidden fees, no surprises. Every recommendation and cost clearly explained.</div>
      </div>
      <div class="value-item fade-in">
        <div class="value-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 17l-1.5 1.5a2.12 2.12 0 01-3 0L4 16a2.12 2.12 0 010-3l1-1" /><path d="M13 7l1.5-1.5a2.12 2.12 0 013 0L20 8a2.12 2.12 0 010 3l-1 1" /><path d="M8 12l4 4" /><path d="M12 8l4 4" /><path d="M3.5 11L8 6.5" /><path d="M16 17.5L20.5 13" /></svg></div>
        <div class="value-name">Long-Term Partnership</div>
        <div class="value-desc">We grow with you — through life changes, market shifts, and every milestone.</div>
      </div>
      <div class="value-item fade-in">
        <div class="value-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="6" /><circle cx="12" cy="12" r="2" /></svg></div>
        <div class="value-name">Personalized Strategy</div>
        <div class="value-desc">Your financial plan is built for your life — not templated from a shelf.</div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="about-preview">
      <div class="about-preview-text">
        <div class="section-eyebrow dark">Who We Are</div>
        <h2 class="section-title">Your Virtual<br />Family Office</h2>
        <p class="section-subtitle">We built Canyon Strategic Wealth around a simple belief: that financial planning done well is deeply personal. Every recommendation, every strategy, is grounded in your unique story.</p>
        <div class="about-features">
          <div class="about-feature">
            <div class="about-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18" /><polyline points="17 6 23 6 23 12" /></svg></div>
            <div>
              <h4>Strategic Coordination</h4>
              <p>We quarterback across investments, taxes, estate planning, and risk management.</p>
            </div>
          </div>
          <div class="about-feature">
            <div class="about-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87" /><path d="M16 3.13a4 4 0 010 7.75" /></svg></div>
            <div>
              <h4>Professional Team Alignment</h4>
              <p>We coordinate with your CPA, attorney, and insurance specialists to keep everything working together.</p>
            </div>
          </div>
          <div class="about-feature">
            <div class="about-feature-icon"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg></div>
            <div>
              <h4>Year-Round Engagement</h4>
              <p>Biannual meetings, proactive check-ins, and continuous coordination — not a once-a-year review.</p>
            </div>
          </div>
        </div>
        <div style="margin-top:32px;">
          <a class="btn btn-navy" href="/team">Meet Our Team</a>
        </div>
      </div>
      <div class="about-preview-visual">
        <div class="about-card-stack">
          <div class="about-floating-card">
            <div class="afc-number">360&deg;</div>
            <div class="afc-label">Holistic financial coordination</div>
            <div class="afc-bar"><div class="afc-bar-fill" style="width:92%"></div></div>
          </div>
          <div class="about-floating-card">
            <div class="afc-number">8</div>
            <div class="afc-label">Structured onboarding meetings</div>
            <div class="afc-bar"><div class="afc-bar-fill" style="width:85%"></div></div>
          </div>
          <div class="about-floating-card">
            <div class="afc-number">4x</div>
            <div class="afc-label">Annual touchpoints minimum</div>
            <div class="afc-bar"><div class="afc-bar-fill" style="width:100%"></div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div style="text-align:center;margin-bottom:48px;position:relative;z-index:2;">
      <div class="section-eyebrow">What We Do</div>
      <h2 class="section-title light">Comprehensive Wealth Management</h2>
      <p class="section-subtitle light" style="margin:0 auto;">From investment strategy to estate planning, we coordinate every aspect of your financial life.</p>
    </div>
    <div class="services-grid">
      <a class="service-card" href="/services/investment-management">
        <div class="service-icon sky"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><path d="M14.5 9.5c-.5-1-1.5-1.5-2.5-1.5-1.66 0-3 1-3 2.5S10.34 13 12 13c1.66 0 3 1 3 2.5S13.66 18 12 18c-1 0-2-.5-2.5-1.5" /><path d="M12 6v2" /><path d="M12 16v2" /></svg></div>
        <h3>Investment Management</h3>
        <p>Strategic portfolio construction, ongoing monitoring, and tax-efficient management aligned with your goals and risk profile.</p>
      </a>
      <a class="service-card" href="/services/financial-planning">
        <div class="service-icon gold"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2" /><rect x="8" y="2" width="8" height="4" rx="1" ry="1" /><line x1="8" y1="10" x2="16" y2="10" /><line x1="8" y1="14" x2="16" y2="14" /><line x1="8" y1="18" x2="12" y2="18" /></svg></div>
        <h3>Financial Planning</h3>
        <p>Comprehensive planning that covers retirement projections, cash flow optimization, education funding, and more.</p>
      </a>
      <a class="service-card" href="/services/tax-strategy">
        <div class="service-icon sky"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg></div>
        <h3>Tax Strategy</h3>
        <p>Proactive tax planning coordinated with your CPA — Roth conversions, tax-loss harvesting, and year-round optimization.</p>
      </a>
      <a class="service-card" href="/services/estate-planning">
        <div class="service-icon gold"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg></div>
        <h3>Estate Planning</h3>
        <p>Legacy protection through coordinated estate strategies, trust reviews, and beneficiary management.</p>
      </a>
      <a class="service-card" href="/services/risk-management">
        <div class="service-icon sky"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /></svg></div>
        <h3>Risk Management</h3>
        <p>Comprehensive insurance review and gap analysis to protect your family, assets, and business.</p>
      </a>
      <a class="service-card" href="/services/business-owner-advisory">
        <div class="service-icon gold"><svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1" /><line x1="9" y1="6" x2="9" y2="6.01" /><line x1="15" y1="6" x2="15" y2="6.01" /><line x1="9" y1="10" x2="9" y2="10.01" /><line x1="15" y1="10" x2="15" y2="10.01" /><line x1="9" y1="14" x2="9" y2="14.01" /><line x1="15" y1="14" x2="15" y2="14.01" /><path d="M10 22v-4h4v4" /></svg></div>
        <h3>Business Owner Advisory</h3>
        <p>Strategic planning for business owners — enterprise valuation, succession planning, and wealth integration.</p>
      </a>
    </div>
    <div style="text-align:center;margin-top:40px;position:relative;z-index:2;">
      <a class="btn btn-primary" href="/services">Explore All Services</a>
    </div>
  </section>

  <section class="lead-magnet fade-in" role="region" aria-label="Free Guide Download">
    <div class="lead-magnet-inner">
      <div class="lead-magnet-badge">Free Guide</div>
      <h2>The Family Wealth Coordination Checklist</h2>
      <p>7 critical areas most families overlook — and how a coordinated strategy can protect your legacy. Download our complimentary guide.</p>
      <form class="lead-magnet-form" id="guideForm" action="/api/contact" method="POST">
        <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none" />
        <input type="hidden" name="formType" value="guide" />
        <input type="email" name="email" placeholder="Enter your email address" aria-label="Email address for guide download" required />
        <button type="submit" class="btn btn-gold">Get the Free Guide <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-left:4px"><line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" /></svg></button>
      </form>
      <p class="form-status" id="guideStatus" role="status" aria-live="polite" style="margin-top:12px;font-size:13px;min-height:1em;"></p>
      <p class="lead-magnet-disclaimer">We respect your privacy. Unsubscribe anytime. No spam, ever.</p>
    </div>
  </section>

  <CtaBand
    heading="Ready to Get Started?"
    text="Schedule a complimentary discovery call to see if we're the right fit for your financial life."
    ctaLabel="Schedule Your Discovery Call"
  />

  <script>
    const form = document.getElementById('guideForm') as HTMLFormElement | null;
    const status = document.getElementById('guideStatus');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      const payload: Record<string, string> = {};
      new FormData(form).forEach((value, key) => {
        payload[key] = String(value);
      });
      if (status) status.textContent = '';
      if (btn && !btn.dataset.label) btn.dataset.label = btn.innerHTML;
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Sending…';
      }
      fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
        .then((res) =>
          res
            .json()
            .catch(() => ({}))
            .then((data) => ({ ok: res.ok, data })),
        )
        .then((result) => {
          if (!status) return;
          if (result.ok) {
            form.reset();
            status.textContent =
              'Thank you. We will send the Family Wealth Coordination Checklist to your inbox shortly.';
            status.style.color = '#A7F3D0';
          } else {
            status.textContent =
              (result.data && (result.data as { error?: string }).error) ||
              'Something went wrong. Please email jake@canyonstrategicwealth.com.';
            status.style.color = '#FCA5A5';
          }
        })
        .catch(() => {
          if (status) {
            status.textContent = 'Something went wrong. Please email jake@canyonstrategicwealth.com.';
            status.style.color = '#FCA5A5';
          }
        })
        .then(() => {
          if (btn) {
            btn.disabled = false;
            if (btn.dataset.label) btn.innerHTML = btn.dataset.label;
          }
        });
    });
  </script>
</BaseLayout>
