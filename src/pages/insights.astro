---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';

const posts = (await getCollection('insights')).sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);
---

<BaseLayout
  title="Insights & Resources | Canyon Strategic Wealth"
  description="Practical, fiduciary-voice guidance on coordinated wealth planning — virtual family office, business exit planning, fiduciary advice, and tax strategy — from Canyon Strategic Wealth."
>
  <div class="page-header">
    <h1>Insights &amp; Resources</h1>
    <p>Practical guidance from our virtual family office on the questions that actually move the needle.</p>
  </div>

  <section class="section">
    <div class="insights-list">
      {
        posts.map((post) => {
          const date = post.data.publishedAt.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <a class="insights-list-item" href={`/insights/${post.id}`}>
              <div class="insights-list-meta">
                <span class="insights-list-cat">{post.data.category}</span>
                <span class="insights-list-date">{date}</span>
                {post.data.minutes && (
                  <span class="insights-list-mins">{post.data.minutes} min read</span>
                )}
              </div>
              <h2 class="insights-list-title">{post.data.title}</h2>
              <p class="insights-list-summary">{post.data.summary}</p>
              <span class="insights-list-link">Read the full article →</span>
            </a>
          );
        })
      }
    </div>
  </section>

  <CtaBand
    heading="Have a Question About Your Situation?"
    text="Schedule a complimentary discovery call and let's talk through what matters most to your family."
    ctaLabel="Schedule a Discovery Call"
  />
</BaseLayout>

<style>
  .insights-list {
    max-width: 880px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .insights-list-item {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--white);
    border-radius: 16px;
    padding: 32px 36px;
    border: 1px solid rgba(27, 58, 92, 0.06);
    box-shadow: 0 4px 20px rgba(27, 58, 92, 0.05);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }

  .insights-list-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 40px rgba(27, 58, 92, 0.12);
  }

  .insights-list-meta {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }

  .insights-list-cat {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--gold);
  }

  .insights-list-date,
  .insights-list-mins {
    font-size: 12px;
    color: var(--text-light);
  }

  .insights-list-title {
    font-family: 'Playfair Display', serif;
    font-size: 24px;
    color: var(--navy);
    line-height: 1.3;
    margin-bottom: 10px;
  }

  .insights-list-summary {
    font-size: 14px;
    color: var(--text-light);
    line-height: 1.7;
    margin-bottom: 14px;
  }

  .insights-list-link {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--navy);
  }

  .insights-list-item:hover .insights-list-link {
    color: var(--sky);
  }

  @media (max-width: 640px) {
    .insights-list-item {
      padding: 24px 24px;
    }
    .insights-list-title {
      font-size: 20px;
    }
  }
</style>
