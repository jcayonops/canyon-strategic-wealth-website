---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';

export async function getStaticPaths() {
  const posts = await getCollection('insights');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const baseUrl = 'https://canyonstrategicwealth.com';
const url = `${baseUrl}/insights/${post.id}`;

const formattedDate = post.data.publishedAt.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: post.data.publishedAt.toISOString(),
  inLanguage: 'en-US',
  author: {
    '@type': 'Person',
    name: 'Jake Cazier',
    jobTitle: 'Private Wealth Advisor',
    url: `${baseUrl}/team`,
  },
  publisher: {
    '@type': 'FinancialService',
    name: 'Canyon Strategic Wealth',
    url: baseUrl,
    logo: {
      '@type': 'ImageObject',
      url: `${baseUrl}/canyon-logo.png`,
    },
  },
  mainEntityOfPage: url,
  url,
  articleSection: post.data.category,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${baseUrl}/` },
    { '@type': 'ListItem', position: 2, name: 'Insights', item: `${baseUrl}/insights` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
---

<BaseLayout
  title={`${post.data.title} | Canyon Strategic Wealth Insights`}
  description={post.data.description}
  ogType="article"
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify([articleSchema, breadcrumbSchema])}
    is:inline
  />

  <div class="page-header insights-article-header">
    <div class="insights-article-eyebrow">
      <span>{post.data.category}</span>
      <span class="dot">·</span>
      <span>{formattedDate}</span>
      {post.data.minutes && (
        <>
          <span class="dot">·</span>
          <span>{post.data.minutes} min read</span>
        </>
      )}
    </div>
    <h1>{post.data.title}</h1>
  </div>

  <article class="section">
    <div class="article-body">
      <Content />
    </div>
    {
      post.data.relatedHref && (
        <div class="article-related">
          <a class="btn btn-primary" href={post.data.relatedHref}>
            {post.data.relatedLabel ?? 'Learn more'}
          </a>
        </div>
      )
    }
    <div class="article-back">
      <a href="/insights">← Back to all insights</a>
    </div>
  </article>

  <CtaBand
    heading="Want to Talk This Through?"
    text="Schedule a complimentary discovery call and we'll walk through your situation together."
    ctaLabel="Schedule a Discovery Call"
  />
</BaseLayout>

<style>
  .insights-article-header h1 {
    max-width: 880px;
    margin: 0 auto;
  }

  .insights-article-eyebrow {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--sky);
    font-weight: 700;
    margin-bottom: 18px;
    position: relative;
    z-index: 2;
  }

  .insights-article-eyebrow .dot {
    opacity: 0.5;
  }

  .article-body {
    max-width: 720px;
    margin: 0 auto;
    color: var(--text);
    font-size: 17px;
    line-height: 1.85;
  }

  .article-body :global(h2) {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    color: var(--navy);
    margin: 56px 0 16px;
    line-height: 1.3;
  }

  .article-body :global(h3) {
    font-family: 'Playfair Display', serif;
    font-size: 21px;
    color: var(--navy);
    margin: 36px 0 12px;
  }

  .article-body :global(p) {
    margin-bottom: 22px;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0 0 22px 24px;
  }

  .article-body :global(li) {
    margin-bottom: 10px;
  }

  .article-body :global(strong) {
    color: var(--navy-deep);
  }

  .article-body :global(a) {
    color: var(--navy);
    border-bottom: 1px solid var(--sky);
    text-decoration: none;
    transition: color 0.2s;
  }

  .article-body :global(a:hover) {
    color: var(--sky);
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--sky);
    padding: 4px 0 4px 20px;
    margin: 24px 0;
    color: var(--text-light);
    font-style: italic;
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid rgba(27, 58, 92, 0.1);
    margin: 36px 0;
  }

  .article-body :global(code) {
    background: var(--gray);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .article-related {
    max-width: 720px;
    margin: 48px auto 0;
    text-align: center;
  }

  .article-back {
    max-width: 720px;
    margin: 32px auto 0;
    text-align: center;
  }

  .article-back a {
    font-size: 13px;
    color: var(--text-light);
    text-decoration: none;
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .article-back a:hover {
    color: var(--navy);
  }

  @media (max-width: 640px) {
    .article-body {
      font-size: 16px;
    }
    .article-body :global(h2) {
      font-size: 24px;
      margin-top: 40px;
    }
    .article-body :global(h3) {
      font-size: 19px;
    }
  }
</style>
