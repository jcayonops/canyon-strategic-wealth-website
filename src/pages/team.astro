---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';

const peopleSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Jake Cazier',
    jobTitle: 'Private Wealth Advisor & Owner',
    worksFor: { '@type': 'FinancialService', name: 'Canyon Strategic Wealth' },
    hasCredential: {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'Professional Certification',
      name: 'CERTIFIED FINANCIAL PLANNER (CFP)',
    },
    image: 'https://canyonstrategicwealth.com/jake-cazier.jpg',
    email: 'jake@canyonstrategicwealth.com',
    telephone: '+1-801-903-8287',
    url: 'https://canyonstrategicwealth.com/team',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Shawnee Lowry',
    jobTitle: 'Administrative / Executive Assistant',
    worksFor: { '@type': 'FinancialService', name: 'Canyon Strategic Wealth' },
    image: 'https://canyonstrategicwealth.com/shawnee-lowry.jpg',
    email: 'shawnee@canyonstrategicwealth.com',
    url: 'https://canyonstrategicwealth.com/team',
  },
];
---

<BaseLayout
  title="Our Team | Canyon Strategic Wealth"
  description="Meet the team behind Canyon Strategic Wealth — led by Jake Cazier, CFP, a fiduciary private wealth advisor in Bountiful, Utah."
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(peopleSchema)}
    is:inline
  />

  <div class="page-header">
    <h1>The People Behind Your Plan</h1>
    <p>A dedicated team committed to your financial success.</p>
  </div>

  <section class="section" style="background:var(--gray);">
    <div class="team-grid">
      <div class="team-member fade-in">
        <div class="team-photo">
          <img src="/jake-cazier.jpg" alt="Jake Cazier, CFP" width="400" height="354" />
        </div>
        <div class="team-name">Jake Cazier, CFP&reg;</div>
        <div class="team-title-text">Private Wealth Advisor &amp; Owner</div>
        <div class="team-bio">Jake leads the firm with a passion for holistic wealth management. As a CERTIFIED FINANCIAL PLANNER&trade; professional, he coordinates every aspect of your financial life — from investments and tax strategy to estate planning and risk management.</div>
        <div class="team-contact">
          <a href="mailto:jake@canyonstrategicwealth.com">Email</a>
          <a href="tel:+18019038287">Call</a>
        </div>
      </div>
      <div class="team-member fade-in">
        <div class="team-photo">
          <img src="/shawnee-lowry.jpg" alt="Shawnee Lowry" width="400" height="400" />
        </div>
        <div class="team-name">Shawnee Lowry</div>
        <div class="team-title-text">Administrative / Executive Assistant</div>
        <div class="team-bio">Shawnee ensures every client interaction is seamless and every detail is handled. She manages client communications, scheduling, and operational coordination across all accounts.</div>
        <div class="team-contact">
          <a href="mailto:shawnee@canyonstrategicwealth.com">Email</a>
          <a href="tel:+13855909757">Call</a>
        </div>
      </div>
      <div class="team-member fade-in">
        <div class="team-photo">
          <div class="team-photo-initials">BS</div>
        </div>
        <div class="team-name">Brizden Staker</div>
        <div class="team-title-text">Operations Intern</div>
        <div class="team-bio">Brizden supports the team with administrative operations, document management, and client onboarding logistics — keeping everything running smoothly behind the scenes.</div>
        <div class="team-contact">
          <a href="mailto:brizden@canyonstrategicwealth.com">Email</a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Ready to Join the Canyon Family?"
    text="Schedule a complimentary discovery call and let's explore how we can help."
    ctaLabel="Schedule Your Discovery Call"
  />
</BaseLayout>
